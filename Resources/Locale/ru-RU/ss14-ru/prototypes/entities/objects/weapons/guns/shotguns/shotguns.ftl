ent-BaseWeaponShotgun = BaseWeaponShotgun
    .desc = Дерзай — налетай, целься и стреляй.
    .suffix = Дробовик
ent-NFWeaponShotgunBulldog = M-12 «Бульдог»
    .desc = Нелегальное оружие используемое агентами Cиндиката. Магазинный дробовик, предназначенный для ведения ближнего боя. Использует патроны калибра .50 ружейный.
    .suffix = Дробовик
ent-NFWeaponShotgunEnforcer = Силовик
    .desc = Боевой дробовик премиум-класса, созданный на основе конструкции Каммерера, с увеличенной ёмкостью магазина. Использует патроны калибра .50 ружейный. Запрещено к использованию гражданскими.
    .suffix = Дробовик
ent-NFWeaponShotgunEnforcerLessLethal = { ent-NFWeaponShotgunEnforcer }
    .desc = { ent-NFWeaponShotgunEnforcer.desc }
    .suffix = Дробовик, Травматический
